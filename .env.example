# Copy to .env for local overrides. docker-compose.yml ships with working local defaults.

# ---- Database ----
POSTGRES_USER=lablumen
POSTGRES_PASSWORD=lablumen
POSTGRES_DB=lablumen
# App (async driver) / Alembic (sync driver) connection strings
DATABASE_URL=postgresql+asyncpg://lablumen:lablumen@postgres:5432/lablumen

# ---- Redis (JWKS cache + appointment slot-locks) ----
REDIS_URL=redis://redis:6379/0

# ---- AWS / Cognito (placeholders for local; real values via Secrets Manager in cluster) ----
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- report-service ----
REPORTS_S3_BUCKET=lablumen-reports-local
PRESIGNED_URL_TTL_SECONDS=120

# ---- notification-service ----
NOTIFICATIONS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/000000000000/lablumen-notifications
SES_SENDER_EMAIL=no-reply@lablumen.local

# ---- Bedrock model IDs (statically pinned) ----
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v1
BEDROCK_TEXT_MODEL_ID=amazon.nova-2-lite-v1:0
